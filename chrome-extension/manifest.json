{
  "manifest_version": 3,
  "name": "VoiceFront — Dialogue Booster",
  "version": "1.0",
  "description": "Boost dialogue and reduce background noise on any video in real-time. Works on YouTube, Netflix, Prime, Hotstar and more.",
  "permissions": ["tabCapture", "offscreen"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VoiceFront",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "web_accessible_resources": [
    { "resources": ["separator-worklet.js"], "matches": ["<all_urls>"] }
  ]
}
